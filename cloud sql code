CREATE TABLE `sync_queue` (
	`id` integer PRIMARY KEY AUTOINCREMENT,
	`table_name` text NOT NULL,
	`record_id` text NOT NULL,
	`operation` text NOT NULL,
	`data` text,
	`synced` numeric DEFAULT 0,
	`retry_count` integer DEFAULT 0,
	`last_error` text,
	`created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	CONSTRAINT "sync_queue_check_40" CHECK(operation IN ('INSERT', 'UPDATE', 'DELETE'))
);
CREATE TABLE `sync_metadata` (
	`key` text PRIMARY KEY,
	`value` text,
	`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
CREATE TABLE `sync_history` (
	`id` integer PRIMARY KEY AUTOINCREMENT,
	`sync_type` text NOT NULL,
	`sync_direction` text,
	`status` text,
	`records_pushed` integer DEFAULT 0,
	`records_pulled` integer DEFAULT 0,
	`errors_count` integer DEFAULT 0,
	`error_details` text,
	`started_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	`completed_at` TIMESTAMP,
	`duration_ms` integer,
	CONSTRAINT "sync_history_check_41" CHECK(sync_type IN ('manual', 'auto', 'background', 'event')),
	CONSTRAINT "sync_history_check_42" CHECK(sync_direction IN ('push', 'pull', 'both')),
	CONSTRAINT "sync_history_check_43" CHECK(status IN ('started', 'completed', 'failed', 'partial'))
);
CREATE TABLE `failed_sync_queue` (
	`id` integer PRIMARY KEY AUTOINCREMENT,
	`original_queue_id` integer,
	`table_name` text NOT NULL,
	`record_id` text NOT NULL,
	`operation` text NOT NULL,
	`data` text,
	`error_message` text,
	`retry_count` integer DEFAULT 0,
	`last_attempt_at` TIMESTAMP,
	`status` text DEFAULT 'pending',
	`created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	`resolved_at` TIMESTAMP,
	CONSTRAINT "failed_sync_queue_check_44" CHECK(status IN ('pending', 'resolved', 'ignored'))
);
CREATE TABLE `sync_locks` (
	`id` integer PRIMARY KEY AUTOINCREMENT,
	`lock_key` text NOT NULL UNIQUE,
	`locked_by` text,
	`locked_at` TIMESTAMP,
	`expires_at` TIMESTAMP,
	`created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
